      "unit": "px",
      "label": "Border radius",
      "default": 20
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding left and right",
      "default": 28
    },
    {
      "type": "header",
      "content": "Arrows"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Arrow size",
      "default": 50
    },
    {
      "type": "range",
      "id": "arrow_offset",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Arrow offset from edge",
      "default": 20
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_hover_background",
      "label": "Arrow hover background",
      "default": "#eff0f5"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow icon color",
      "default": "#0e1b4d"
    }
  ],
  "presets": [
    {
      "name": "Sliding images"
    }
  ]
}
{% endschema %}
