{% doc %}
  @prompt
    create a new section for freight services with a heading and subheading and 6 cards where it has image and headings and paragraph on each cards. 3 cards on top and 3 cards on bottom. also put a setting where i can modify the image size, width, height. as well as the cards padding, gap, height and width. make it mobile responsive. make it animation where if someone click a certain card, duplicate the design of the #portfolio section on the homepage
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-freight-services-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-freight-services-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-freight-services-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_margin_bottom }}px;
  }

  .ai-freight-services-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    font-weight: 700;
  }

  .ai-freight-services-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-freight-services-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-freight-service-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    height: {{ block.settings.card_height }}px;
    width: {{ block.settings.card_width }}%;
    display: flex;
    flex-direction: column;
  }

  .ai-freight-service-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-freight-service-card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 20px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-freight-service-card-image-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    display: block;
    margin: 0 auto;
  }

  .ai-freight-service-card-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-freight-service-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-freight-service-card-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-freight-service-card-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_heading_size }}px;
    color: {{ block.settings.card_heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-freight-service-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-freight-modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    z-index: 9999;
    overflow-y: auto;
    padding: 40px 20px;
  }

  .ai-freight-modal-{{ ai_gen_id }}.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-freight-modal-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.modal_background_color }};
    border-radius: {{ block.settings.modal_border_radius }}px;
    max-width: 900px;
    width: 100%;
    position: relative;
    padding: 60px 40px 40px;
    max-height: 90vh;
    overflow-y: auto;
  }

  .ai-freight-modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    font-size: 32px;
    cursor: pointer;
    color: {{ block.settings.modal_text_color }};
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background-color 0.3s ease;
  }

  .ai-freight-modal-close-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.1);
  }

  .ai-freight-modal-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 30px;
    overflow: hidden;
    border-radius: {{ block.settings.modal_image_border_radius }}px;
  }

  .ai-freight-modal-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.modal_image_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-freight-modal-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.modal_image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.modal_image_border_radius }}px;
  }

  .ai-freight-modal-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-freight-modal-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.modal_heading_size }}px;
    color: {{ block.settings.modal_text_color }};
    margin: 0 0 20px;
    font-weight: 700;
  }

  .ai-freight-modal-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.modal_text_size }}px;
    color: {{ block.settings.modal_text_color }};
    line-height: 1.8;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-freight-services-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-freight-service-card-{{ ai_gen_id }} {
      width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-freight-services-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-freight-services-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-freight-services-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-freight-service-card-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
    }

    .ai-freight-modal-content-{{ ai_gen_id }} {
      padding: 50px 20px 30px;
    }

    .ai-freight-modal-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.modal_heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<freight-services-{{ ai_gen_id }} class="ai-freight-services-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-freight-services-container-{{ ai_gen_id }}">
    <div class="ai-freight-services-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-freight-services-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-freight-services-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-freight-services-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_heading_key = 'card_' | append: i | append: '_heading'
          assign card_text_key = 'card_' | append: i | append: '_text'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_image = block.settings[card_image_key]
          assign card_heading = block.settings[card_heading_key]
          assign card_text = block.settings[card_text_key]
        %}

        {% if card_enabled %}
          <div class="ai-freight-service-card-{{ ai_gen_id }}" data-card-index="{{ i }}">
            <div class="ai-freight-service-card-image-wrapper-{{ ai_gen_id }}">
              {% if card_image %}
                <img
                  src="{{ card_image | image_url: width: 800 }}"
                  alt="{{ card_image.alt | escape }}"
                  class="ai-freight-service-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}"
                >
              {% else %}
                <div class="ai-freight-service-card-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-freight-service-card-content-{{ ai_gen_id }}">
              {% if card_heading != blank %}
                <h3 class="ai-freight-service-card-heading-{{ ai_gen_id }}">{{ card_heading }}</h3>
              {% endif %}
              {% if card_text != blank %}
                <div class="ai-freight-service-card-text-{{ ai_gen_id }}">{{ card_text }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ai-freight-modal-{{ ai_gen_id }}" id="ai-freight-modal-{{ ai_gen_id }}">
    <div class="ai-freight-modal-content-{{ ai_gen_id }}">
      <button class="ai-freight-modal-close-{{ ai_gen_id }}" aria-label="Close modal">&times;</button>
      <div class="ai-freight-modal-image-wrapper-{{ ai_gen_id }}" id="ai-freight-modal-image-wrapper-{{ ai_gen_id }}"></div>
      <h3 class="ai-freight-modal-heading-{{ ai_gen_id }}" id="ai-freight-modal-heading-{{ ai_gen_id }}"></h3>
      <div class="ai-freight-modal-text-{{ ai_gen_id }}" id="ai-freight-modal-text-{{ ai_gen_id }}"></div>
    </div>
  </div>
</freight-services-{{ ai_gen_id }}>

<script>
  (function() {
    class FreightServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.cards = [];
        this.modal = null;
        this.modalImageWrapper = null;
        this.modalHeading = null;
        this.modalText = null;
        this.closeButton = null;
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-freight-service-card-{{ ai_gen_id }}');
        this.modal = this.querySelector('#ai-freight-modal-{{ ai_gen_id }}');
        this.modalImageWrapper = this.querySelector('#ai-freight-modal-image-wrapper-{{ ai_gen_id }}');
        this.modalHeading = this.querySelector('#ai-freight-modal-heading-{{ ai_gen_id }}');
        this.modalText = this.querySelector('#ai-freight-modal-text-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-freight-modal-close-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('click', () => {
            const cardIndex = card.getAttribute('data-card-index');
            this.openModal(cardIndex);
          });
        });

        this.closeButton.addEventListener('click', () => {
          this.closeModal();
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      openModal(cardIndex) {
        const card = this.querySelector(`[data-card-index="${cardIndex}"]`);
        if (!card) return;

        const imageWrapper = card.querySelector('.ai-freight-service-card-image-wrapper-{{ ai_gen_id }}');
        const heading = card.querySelector('.ai-freight-service-card-heading-{{ ai_gen_id }}');
        const text = card.querySelector('.ai-freight-service-card-text-{{ ai_gen_id }}');

        this.modalImageWrapper.innerHTML = imageWrapper.innerHTML;
        
        const modalImage = this.modalImageWrapper.querySelector('.ai-freight-service-card-image-{{ ai_gen_id }}');
        if (modalImage) {
          modalImage.classList.remove('ai-freight-service-card-image-{{ ai_gen_id }}');
          modalImage.classList.add('ai-freight-modal-image-{{ ai_gen_id }}');
        }

        const modalPlaceholder = this.modalImageWrapper.querySelector('.ai-freight-service-card-placeholder-{{ ai_gen_id }}');
        if (modalPlaceholder) {
          modalPlaceholder.classList.remove('ai-freight-service-card-placeholder-{{ ai_gen_id }}');
          modalPlaceholder.classList.add('ai-freight-modal-placeholder-{{ ai_gen_id }}');
        }

        this.modalHeading.textContent = heading ? heading.textContent : '';
        this.modalText.innerHTML = text ? text.innerHTML : '';

        this.modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeModal() {
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    customElements.define('freight-services-{{ ai_gen_id }}', FreightServices{{ ai_gen_id }});
  })();
</script>

