    },
    {
      "type": "color",
      "id": "secondary_button_bg_hover",
      "label": "Hover background",
      "default": "#eff0f5"
    },
    {
      "type": "color",
      "id": "secondary_button_text_hover",
      "label": "Hover text",
      "default": "#0e1b4d"
    }
