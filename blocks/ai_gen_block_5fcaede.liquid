{% doc %}
  @prompt
    create a new section on what i bring to your team where it has 4 cards and each crads must have an image on the top and the text below. 2 cards on top on 2 cards below. must have a settings to adjust the image size and card size so i can make sure that i ca just adjsut everything
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-team-cards-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-team-cards-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-team-cards-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-team-cards-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-team-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.card_text_alignment }};
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    box-shadow: 0 {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
  }

  .ai-team-card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.image_text_spacing }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-team-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-team-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-team-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-team-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.title_text_spacing }}px;
    font-weight: 600;
  }

  .ai-team-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-team-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-team-cards-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-team-card-image-{{ ai_gen_id }},
    .ai-team-card-image-placeholder-{{ ai_gen_id }} {
      height: calc({{ block.settings.image_height }}px * 0.8);
    }
  }
{% endstyle %}

<team-cards-{{ ai_gen_id }}
  class="ai-team-cards-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-team-cards-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-team-cards-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-team-cards-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign title_key = 'card_' | append: i | append: '_title'
          assign text_key = 'card_' | append: i | append: '_text'

          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_text = block.settings[text_key]
        %}

        <div class="ai-team-card-{{ ai_gen_id }}">
          <div class="ai-team-card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-team-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-team-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if card_title != blank %}
            <h3 class="ai-team-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
          {% endif %}

          {% if card_text != blank %}
            <div class="ai-team-card-text-{{ ai_gen_id }}">{{ card_text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</team-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class TeamCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('team-cards-{{ ai_gen_id }}', TeamCards{{ ai_gen_id }});
  })();
</script>

