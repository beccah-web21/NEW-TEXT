{% doc %}
  @prompt
    creating a scrolling section where i can put diiferent logos for the tools that i used on training , make it for 6 logos only. make the section padding height a little bit shotert. no need to put text just the scrolling logos only 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-scroll-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-logo-scroll-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-logo-scroll-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    animation: ai-logo-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-logo-scroll-track-{{ ai_gen_id }}:hover {
    animation-play-state: {% if block.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  .ai-logo-scroll-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    background-color: {{ block.settings.logo_background }};
    border-radius: {{ block.settings.logo_border_radius }}px;
    padding: {{ block.settings.logo_padding }}px;
  }

  .ai-logo-scroll-item-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale({{ block.settings.grayscale_amount }}%);
    opacity: {{ block.settings.logo_opacity }};
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .ai-logo-scroll-item-{{ ai_gen_id }}:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }

  .ai-logo-scroll-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.logo_border_radius }}px;
  }

  .ai-logo-scroll-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-logo-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-100% - {{ block.settings.logo_spacing }}px));
    }
  }

  @media screen and (max-width: 749px) {
    .ai-logo-scroll-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-logo-scroll-item-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.8 }}px;
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<logo-scroll-{{ ai_gen_id }} class="ai-logo-scroll-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-scroll-container-{{ ai_gen_id }}">
    <div class="ai-logo-scroll-track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign logo_key = 'logo_' | append: i
          assign logo = block.settings[logo_key]
        %}
        
        {% if logo != blank %}
          <div class="ai-logo-scroll-item-{{ ai_gen_id }}">
            <img
              src="{{ logo | image_url: width: 400 }}"
              alt="{{ logo.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.logo_width }}"
              height="{{ block.settings.logo_height }}"
            >
          </div>
        {% else %}
          <div class="ai-logo-scroll-item-{{ ai_gen_id }}">
            <div class="ai-logo-scroll-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% for i in (1..6) %}
        {% liquid
          assign logo_key = 'logo_' | append: i
          assign logo = block.settings[logo_key]
        %}
        
        {% if logo != blank %}
          <div class="ai-logo-scroll-item-{{ ai_gen_id }}">
            <img
              src="{{ logo | image_url: width: 400 }}"
              alt="{{ logo.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.logo_width }}"
              height="{{ block.settings.logo_height }}"
            >
          </div>
        {% else %}
          <div class="ai-logo-scroll-item-{{ ai_gen_id }}">
            <div class="ai-logo-scroll-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</logo-scroll-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-logo-scroll-track-{{ ai_gen_id }}');
        this.adjustAnimation();
      }

      adjustAnimation() {
        if (!this.track) return;
        
        const trackWidth = this.track.scrollWidth / 2;
        this.track.style.setProperty('--track-width', `${trackWidth}px`);
      }
    }

    customElements.define('logo-scroll-{{ ai_gen_id }}', LogoScroll{{ ai_gen_id }});
  })();
</script>

