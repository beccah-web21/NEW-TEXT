{% doc %}
  @prompt
    create a new section for freight services with a heading and subheading and 6 cards where it has image and headings and paragraph on each cards. 3 cards on top and 3 cards on bottom. also put a setting where i can modify the image size, width, height. as well as the cards padding, gap, height and width. make it mobile responsive. make it animation where if someone click a certain card 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-freight-services-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-freight-services__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-freight-services__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-freight-services__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 700;
  }

  .ai-freight-services__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-freight-services__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-freight-services__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    width: {{ block.settings.card_width }}%;
    height: {{ block.settings.card_height }}px;
    display: flex;
    flex-direction: column;
  }

  .ai-freight-services__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-freight-services__card-{{ ai_gen_id }}.active {
    transform: scale(1.05);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
    border: 2px solid {{ block.settings.card_active_border_color }};
  }

  .ai-freight-services__card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    margin-bottom: 16px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-freight-services__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-freight-services__card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-freight-services__card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-freight-services__card-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-freight-services__card-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_heading_size }}px;
    color: {{ block.settings.card_heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-freight-services__card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-freight-services__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-freight-services__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-freight-services__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-freight-services__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-freight-services__card-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
    }
  }
{% endstyle %}

<freight-services-{{ ai_gen_id }} class="ai-freight-services-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-freight-services__container-{{ ai_gen_id }}">
    <div class="ai-freight-services__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-freight-services__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-freight-services__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-freight-services__grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_heading_key = 'card_' | append: i | append: '_heading'
          assign card_text_key = 'card_' | append: i | append: '_text'
          
          assign card_image = block.settings[card_image_key]
          assign card_heading = block.settings[card_heading_key]
          assign card_text = block.settings[card_text_key]
        %}

        <div class="ai-freight-services__card-{{ ai_gen_id }}" data-card-index="{{ i }}">
          <div class="ai-freight-services__card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="800"
                height="{{ block.settings.image_height }}"
                class="ai-freight-services__card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-freight-services__card-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-freight-services__card-content-{{ ai_gen_id }}">
            {% if card_heading != blank %}
              <h3 class="ai-freight-services__card-heading-{{ ai_gen_id }}">{{ card_heading }}</h3>
            {% endif %}
            {% if card_text != blank %}
              <p class="ai-freight-services__card-text-{{ ai_gen_id }}">{{ card_text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</freight-services-{{ ai_gen_id }}>

<script>
  (function() {
    class FreightServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.cards = [];
        this.activeCard = null;
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-freight-services__card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('click', () => {
            this.handleCardClick(card);
          });
        });
      }

      handleCardClick(clickedCard) {
        if (this.activeCard === clickedCard) {
          clickedCard.classList.remove('active');
          this.activeCard = null;
        } else {
          this.cards.forEach((card) => {
            card.classList.remove('active');
          });
          clickedCard.classList.add('active');
          this.activeCard = clickedCard;
        }
      }
    }

    customElements.define('freight-services-{{ ai_gen_id }}', FreightServices{{ ai_gen_id }});
  })();
</script>

