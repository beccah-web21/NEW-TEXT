{% doc %}
  @prompt
    Create a clean, premium CTA section for  with a professional, client-focused tone. Include a strong headline and a short line emphasizing reliability, efficiency, and support for freight brokers and logistics teams. Add two buttons: a primary CTA (“Request a Quote”) and a secondary CTA (“Get in Touch”). Keep the design minimal, modern, and conversion-focused, similar to a high-end logistics or agency website. Keep all text concise and impactful. each buttons should have a settings where i can put external links so they can redirected to another page when they see it. and the it should have an image background with overlay colors. make this section smaller , put a settings where i can adjust the position of the texts and the buttons and also where i can adjust the padding, width height of the section make it the same size of email newsletter section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-section-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
    min-height: {{ block.settings.section_height }}px;
  }

  .ai-cta-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-cta-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cta-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
  }

  .ai-cta-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cta-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-cta-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_horizontal }}px;
    padding-right: {{ block.settings.padding_horizontal }}px;
    text-align: {{ block.settings.content_alignment }};
    display: flex;
    flex-direction: column;
    {% if block.settings.content_alignment == 'left' %}
      align-items: flex-start;
    {% elsif block.settings.content_alignment == 'right' %}
      align-items: flex-end;
    {% else %}
      align-items: center;
    {% endif %}
    justify-content: {{ block.settings.vertical_alignment }};
    gap: 24px;
    min-height: {{ block.settings.section_height }}px;
    max-width: {{ block.settings.content_max_width }}px;
    {% if block.settings.content_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif block.settings.content_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .ai-cta-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    font-weight: 700;
    width: 100%;
  }

  .ai-cta-subtext-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subtext_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    width: 100%;
  }

  .ai-cta-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    {% if block.settings.content_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.content_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: center;
    {% endif %}
  }

  .ai-cta-button-primary-{{ ai_gen_id }} {
    padding: 16px 32px;
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-cta-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    transform: translateY(-2px);
  }

  .ai-cta-button-secondary-{{ ai_gen_id }} {
    padding: 16px 32px;
    background-color: transparent;
    color: {{ block.settings.secondary_button_color }};
    border: 2px solid {{ block.settings.secondary_button_border }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-cta-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    color: {{ block.settings.secondary_button_hover_color }};
    border-color: {{ block.settings.secondary_button_hover_bg }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-cta-section-{{ ai_gen_id }} {
      min-height: {{ block.settings.section_height | times: 0.7 }}px;
    }

    .ai-cta-content-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.7 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.7 }}px;
      padding-left: 20px;
      padding-right: 20px;
      gap: 16px;
      min-height: {{ block.settings.section_height | times: 0.7 }}px;
      text-align: {{ block.settings.mobile_content_alignment }};
      {% if block.settings.mobile_content_alignment == 'left' %}
        align-items: flex-start;
      {% elsif block.settings.mobile_content_alignment == 'right' %}
        align-items: flex-end;
      {% else %}
        align-items: center;
      {% endif %}
    }

    .ai-cta-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-cta-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-cta-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
      gap: 12px;
      {% if block.settings.mobile_content_alignment == 'left' %}
        justify-content: flex-start;
      {% elsif block.settings.mobile_content_alignment == 'right' %}
        justify-content: flex-end;
      {% else %}
        justify-content: center;
      {% endif %}
    }

    .ai-cta-button-primary-{{ ai_gen_id }},
    .ai-cta-button-secondary-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<freight-cta-{{ ai_gen_id }} class="ai-cta-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cta-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-cta-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-cta-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-cta-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-cta-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-cta-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    <div class="ai-cta-buttons-{{ ai_gen_id }}">
      {% if block.settings.primary_button_label != blank %}
        <a
          href="{{ block.settings.primary_button_link }}"
          class="ai-cta-button-primary-{{ ai_gen_id }}"
        >
          {{ block.settings.primary_button_label }}
        </a>
      {% endif %}

      {% if block.settings.secondary_button_label != blank %}
        <a
          href="{{ block.settings.secondary_button_link }}"
          class="ai-cta-button-secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.secondary_button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</freight-cta-{{ ai_gen_id }}>

<script>
  (function() {
    class FreightCta{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('freight-cta-{{ ai_gen_id }}', FreightCta{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Freight CTA section",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Reliable Freight Solutions for Your Business"
    },
    {
      "type": "inline_richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "Efficiency, reliability, and support you can count on"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "inline_richtext",
      "id": "primary_button_label",
      "label": "Text",
      "default": "Request a Quote"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "primary_button_bg",
      "label": "Background",
      "default": "#4770db"
    },
    {
      "type": "color",
      "id": "primary_button_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_button_hover_bg",
      "label": "Hover background",
      "default": "#0e1b4d"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "inline_richtext",
      "id": "secondary_button_label",
      "label": "Text",
      "default": "Get in Touch"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "secondary_button_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_border",
      "label": "Border color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_hover_bg",
      "label": "Hover background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_hover_color",
      "label": "Hover text color",
      "default": "#0e1b4d"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#0e1b4d"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.6
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_alignment",
