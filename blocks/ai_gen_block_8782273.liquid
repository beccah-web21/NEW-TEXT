{% doc %}
  @prompt
    generate a new section for what i bring to your team.  make it small cards with has icons on top that shows these title. Trained & Coach-Guided
    Organized & Proactive
    Reliable & Consistent
    Detail-Oriented
    Fast Learner
    Night-Shift Ready. note that icon per title per card also put a heading and subheading on top of the 6 cards., also add a paragraph inside each cards. make this cards 3 on 3 on a desktop and laptop view and make it mobile responsive
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-team-value-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-team-value-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-team-value-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-team-value-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 15px 0;
    font-weight: 700;
  }

  .ai-team-value-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    font-weight: 400;
  }

  .ai-team-value-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-team-value-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 30px 20px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-team-value-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-team-value-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
  }

  .ai-team-value-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    fill: {{ block.settings.icon_color }};
  }

  .ai-team-value-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 15px 0;
    font-weight: 600;
  }

  .ai-team-value-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-team-value-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-team-value-section-{{ ai_gen_id }} {
      padding: 40px 15px;
    }

    .ai-team-value-header-{{ ai_gen_id }} {
      margin-bottom: 30px;
    }

    .ai-team-value-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-team-value-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-team-value-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-team-value-card-{{ ai_gen_id }} {
      padding: 25px 15px;
    }
  }
{% endstyle %}

<team-values-{{ ai_gen_id }} class="ai-team-value-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-team-value-container-{{ ai_gen_id }}">
    <div class="ai-team-value-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-team-value-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-team-value-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-team-value-grid-{{ ai_gen_id }}">
      {% if block.settings.card_1_enabled %}
        <div class="ai-team-value-card-{{ ai_gen_id }}">
          <div class="ai-team-value-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
          <p class="ai-team-value-card-text-{{ ai_gen_id }}">{{ block.settings.card_1_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.card_2_enabled %}
        <div class="ai-team-value-card-{{ ai_gen_id }}">
          <div class="ai-team-value-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
            </svg>
          </div>
          <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
          <p class="ai-team-value-card-text-{{ ai_gen_id }}">{{ block.settings.card_2_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.card_3_enabled %}
        <div class="ai-team-value-card-{{ ai_gen_id }}">
          <div class="ai-team-value-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
            </svg>
          </div>
          <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
          <p class="ai-team-value-card-text-{{ ai_gen_id }}">{{ block.settings.card_3_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.card_4_enabled %}
        <div class="ai-team-value-card-{{ ai_gen_id }}">
          <div class="ai-team-value-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
            </svg>
          </div>
          <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_4_title }}</h3>
          <p class="ai-team-value-card-text-{{ ai_gen_id }}">{{ block.settings.card_4_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.card_5_enabled %}
        <div class="ai-team-value-card-{{ ai_gen_id }}">
          <div class="ai-team-value-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/>
            </svg>
          </div>
          <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_5_title }}</h3>
          <p class="ai-team-value-card-text-{{ ai_gen_id }}">{{ block.settings.card_5_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.card_6_enabled %}
        <div class="ai-team-value-card-{{ ai_gen_id }}">
          <div class="ai-team-value-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
            </svg>
          </div>
          <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_6_title }}</h3>
          <p class="ai-team-value-card-text-{{ ai_gen_id }}">{{ block.settings.card_6_text }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</team-values-{{ ai_gen_id }}>

<script>
  (function() {
    class TeamValues{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('team-values-{{ ai_gen_id }}', TeamValues{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "What I bring to your team",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What I Bring to Your Team"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "My core strengths and values"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#eff0f5"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#4770db"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card title size",
      "min": 14,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#0e1b4d"
    },
    {
      "type": "range",
      "id": "card_text_size",
      "label": "Card text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#0e1b4d"
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "checkbox",
      "id": "card_1_enabled",
      "label": "Enable card 1",
      "default": true
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "Trained & Coach-Guided"
    },
    {
      "type": "textarea",
      "id": "card_1_text",
      "label": "Description",
      "default": "I've completed professional training and work with experienced coaches to continuously improve my skills and deliver exceptional results."
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "checkbox",
      "id": "card_2_enabled",
      "label": "Enable card 2",
      "default": true
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "Organized & Proactive"
    },
    {
      "type": "textarea",
      "id": "card_2_text",
      "label": "Description",
      "default": "I maintain structured workflows and anticipate needs before they arise, ensuring smooth operations and timely delivery of all tasks."
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "checkbox",
      "id": "card_3_enabled",
      "label": "Enable card 3",
      "default": true
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Title",
      "default": "Reliable & Consistent"
    },
    {
      "type": "textarea",
      "id": "card_3_text",
      "label": "Description",
      "default": "You can count on me to show up every day with the same level of dedication and quality, building trust through consistent performance."
    },
    {
      "type": "header",
      "content": "Card 4"
    },
    {
      "type": "checkbox",
      "id": "card_4_enabled",
      "label": "Enable card 4",
      "default": true
    },
    {
      "type": "text",
      "id": "card_4_title",
      "label": "Title",
      "default": "Detail-Oriented"
    },
    {
      "type": "textarea",
      "id": "card_4_text",
      "label": "Description",
      "default": "I pay close attention to every detail, ensuring accuracy and quality in all aspects of my work, from small tasks to major projects."
    },
    {
      "type": "header",
      "content": "Card 5"
    },
    {
      "type": "checkbox",
      "id": "card_5_enabled",
      "label": "Enable card 5",
      "default": true
    },
    {
      "type": "text",
      "id": "card_5_title",
      "label": "Title",
      "default": "Fast Learner"
    },
    {
      "type": "textarea",
      "id": "card_5_text",
      "label": "Description",
      "default": "I quickly adapt to new tools, processes, and challenges, allowing me to contribute effectively even in unfamiliar situations."
    },
    {
      "type": "header",
      "content": "Card 6"
    },
    {
      "type": "checkbox",
      "id": "card_6_enabled",
      "label": "Enable card 6",
      "default": true
    },
    {
      "type": "text",
      "id": "card_6_title",
      "label": "Title",
      "default": "Night-Shift Ready"
    },
    {
      "type": "textarea",
      "id": "card_6_text",
