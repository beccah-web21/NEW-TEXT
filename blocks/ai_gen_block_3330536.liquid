{% doc %}
  @prompt
    generate a new section for what i bring to your team.  make it small cards with has icons on top that shows these title. Trained & Coach-Guided
    Organized & Proactive
    Reliable & Consistent
    Detail-Oriented
    Fast Learner
    Night-Shift Ready. note that icon per title per card also put a heading and subheading on top of the 6 cards., also add a paragraph inside each cards 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-team-value-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-team-value-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-team-value-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_subheading_gap }}px;
  }

  .ai-team-value-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-team-value-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: {{ block.settings.card_gap }}px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-team-value-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
  }

  .ai-team-value-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_title_gap }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-team-value-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
  }

  .ai-team-value-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.title_description_gap }}px;
    font-weight: 600;
  }

  .ai-team-value-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-team-value-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    .ai-team-value-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-team-value-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<team-value-section-{{ ai_gen_id }}
  class="ai-team-value-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-team-value-header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-team-value-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.subheading != blank %}
      <p class="ai-team-value-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="ai-team-value-grid-{{ ai_gen_id }}">
    <div class="ai-team-value-card-{{ ai_gen_id }}">
      <div class="ai-team-value-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
      </div>
      <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
      {% if block.settings.card_1_description != blank %}
        <p class="ai-team-value-card-description-{{ ai_gen_id }}">{{ block.settings.card_1_description }}</p>
      {% endif %}
    </div>

    <div class="ai-team-value-card-{{ ai_gen_id }}">
      <div class="ai-team-value-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 11 12 14 22 4"></polyline>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
      </div>
      <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
      {% if block.settings.card_2_description != blank %}
        <p class="ai-team-value-card-description-{{ ai_gen_id }}">{{ block.settings.card_2_description }}</p>
      {% endif %}
    </div>

    <div class="ai-team-value-card-{{ ai_gen_id }}">
      <div class="ai-team-value-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>
      <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
      {% if block.settings.card_3_description != blank %}
        <p class="ai-team-value-card-description-{{ ai_gen_id }}">{{ block.settings.card_3_description }}</p>
      {% endif %}
    </div>

    <div class="ai-team-value-card-{{ ai_gen_id }}">
      <div class="ai-team-value-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          <line x1="11" y1="8" x2="11" y2="14"></line>
          <line x1="8" y1="11" x2="14" y2="11"></line>
        </svg>
      </div>
      <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_4_title }}</h3>
      {% if block.settings.card_4_description != blank %}
        <p class="ai-team-value-card-description-{{ ai_gen_id }}">{{ block.settings.card_4_description }}</p>
      {% endif %}
    </div>

    <div class="ai-team-value-card-{{ ai_gen_id }}">
      <div class="ai-team-value-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
      </div>
      <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_5_title }}</h3>
      {% if block.settings.card_5_description != blank %}
        <p class="ai-team-value-card-description-{{ ai_gen_id }}">{{ block.settings.card_5_description }}</p>
      {% endif %}
    </div>

    <div class="ai-team-value-card-{{ ai_gen_id }}">
      <div class="ai-team-value-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </div>
      <h3 class="ai-team-value-card-title-{{ ai_gen_id }}">{{ block.settings.card_6_title }}</h3>
      {% if block.settings.card_6_description != blank %}
        <p class="ai-team-value-card-description-{{ ai_gen_id }}">{{ block.settings.card_6_description }}</p>
      {% endif %}
    </div>
  </div>
</team-value-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TeamValueSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('team-value-section-{{ ai_gen_id }}', TeamValueSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "What I bring to your team",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What I Bring to Your Team"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Skills and qualities that make me a valuable team member"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_subheading_gap",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "Gap between heading and subheading",
      "default": 10
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Space below header",
      "default": 40
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "Trained & Coach-Guided"
    },
    {
      "type": "textarea",
      "id": "card_1_description",
      "label": "Description",
      "default": "Professionally trained with ongoing coaching support to ensure excellence in every task."
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "Organized & Proactive"
    },
    {
      "type": "textarea",
      "id": "card_2_description",
      "label": "Description",
      "default": "Highly organized with a proactive approach to anticipate needs and solve problems."
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Title",
      "default": "Reliable & Consistent"
    },
    {
      "type": "textarea",
      "id": "card_3_description",
      "label": "Description",
      "default": "Dependable performance you can count on, delivering consistent quality every time."
    },
    {
      "type": "header",
      "content": "Card 4"
    },
    {
      "type": "text",
      "id": "card_4_title",
      "label": "Title",
      "default": "Detail-Oriented"
    },
    {
      "type": "textarea",
      "id": "card_4_description",
      "label": "Description",
      "default": "Meticulous attention to detail ensures accuracy and high-quality outcomes."
    },
    {
      "type": "header",
      "content": "Card 5"
    },
    {
      "type": "text",
      "id": "card_5_title",
      "label": "Title",
      "default": "Fast Learner"
    },
    {
      "type": "textarea",
      "id": "card_5_description",
      "label": "Description",
      "default": "Quick to adapt and master new tools, processes, and systems efficiently."
    },
    {
      "type": "header",
      "content": "Card 6"
    },
    {
      "type": "text",
      "id": "card_6_title",
      "label": "Title",
      "default": "Night-Shift Ready"
    },
    {
      "type": "textarea",
      "id": "card_6_description",
      "label": "Description",
      "default": "Flexible and available to work night shifts to support your business needs."
    },
    {
      "type": "header",
      "content": "Cards style"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Card padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 12
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_shadow_horizontal",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Shadow horizontal offset",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_shadow_vertical",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Shadow vertical offset",
      "default": 4
    },
    {
      "type": "range",
      "id": "card_shadow_blur",
      "min": 0,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "Shadow blur",
      "default": 10
    },
    {
      "type": "range",
      "id": "card_shadow_opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "label": "Shadow opacity",
      "default": 0.1
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Icon size",
      "default": 50
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#4770db"
    },
    {
      "type": "range",
      "id": "icon_title_gap",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Gap between icon and title",
      "default": 20
    },
    {
      "type": "header",
      "content": "Card text"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 16
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Title color",
      "default": "#0e1b4d"
    },
    {
      "type": "range",
      "id": "title_description_gap",
      "min": 5,
      "max": 25,
      "step": 5,
      "unit": "px",
      "label": "Gap between title and description",
      "default": 10
    },
    {
      "type": "range",
      "id": "card_description_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 14
    },
    {
      "type": "color",
      "id": "card_description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 60
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#eff0f5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#0e1b4d"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "What I bring to your team"
    }
  ]
}
{% endschema %}
