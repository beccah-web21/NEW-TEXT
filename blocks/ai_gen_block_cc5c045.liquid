{% doc %}
  @prompt
    create a new section for services offered with 6 cards, 3 cards on top and 3 cards on bottom where the cards are Transportation Coordination,Freight Quoting Assistance,Carrier Coordination,Load Board Support,Documentation Management,Shipment Process Support
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-services-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-services-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-services-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-services-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-weight: 700;
  }

  .ai-services-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-services-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-services-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.card_text_alignment }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    box-shadow: 0 {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
  }

  .ai-services-card-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-services-card-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    stroke: {{ block.settings.icon_color }};
  }

  .ai-services-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-services-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 989px) {
    .ai-services-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-services-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-services-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-services-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }
{% endstyle %}

<services-section-{{ ai_gen_id }}
  class="ai-services-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-services-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-services-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-services-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <div class="ai-services-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-services-grid-{{ ai_gen_id }}">
      {% if block.settings.card_1_enabled %}
        <div class="ai-services-card-{{ ai_gen_id }}">
          <div class="ai-services-card-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <h3 class="ai-services-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
          <div class="ai-services-card-description-{{ ai_gen_id }}">{{ block.settings.card_1_description }}</div>
        </div>
      {% endif %}

      {% if block.settings.card_2_enabled %}
        <div class="ai-services-card-{{ ai_gen_id }}">
          <div class="ai-services-card-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </div>
          <h3 class="ai-services-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
          <div class="ai-services-card-description-{{ ai_gen_id }}">{{ block.settings.card_2_description }}</div>
        </div>
      {% endif %}

      {% if block.settings.card_3_enabled %}
        <div class="ai-services-card-{{ ai_gen_id }}">
          <div class="ai-services-card-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <h3 class="ai-services-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
          <div class="ai-services-card-description-{{ ai_gen_id }}">{{ block.settings.card_3_description }}</div>
        </div>
      {% endif %}

      {% if block.settings.card_4_enabled %}
        <div class="ai-services-card-{{ ai_gen_id }}">
          <div class="ai-services-card-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="3" y1="9" x2="21" y2="9"></line>
              <line x1="9" y1="21" x2="9" y2="9"></line>
            </svg>
          </div>
          <h3 class="ai-services-card-title-{{ ai_gen_id }}">{{ block.settings.card_4_title }}</h3>
          <div class="ai-services-card-description-{{ ai_gen_id }}">{{ block.settings.card_4_description }}</div>
        </div>
      {% endif %}

      {% if block.settings.card_5_enabled %}
        <div class="ai-services-card-{{ ai_gen_id }}">
          <div class="ai-services-card-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <h3 class="ai-services-card-title-{{ ai_gen_id }}">{{ block.settings.card_5_title }}</h3>
          <div class="ai-services-card-description-{{ ai_gen_id }}">{{ block.settings.card_5_description }}</div>
        </div>
      {% endif %}

      {% if block.settings.card_6_enabled %}
        <div class="ai-services-card-{{ ai_gen_id }}">
          <div class="ai-services-card-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
          </div>
          <h3 class="ai-services-card-title-{{ ai_gen_id }}">{{ block.settings.card_6_title }}</h3>
          <div class="ai-services-card-description-{{ ai_gen_id }}">{{ block.settings.card_6_description }}</div>
        </div>
      {% endif %}
    </div>
  </div>
</services-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ServicesSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('services-section-{{ ai_gen_id }}', ServicesSection{{ ai_gen_id }});
  })();
</script>

