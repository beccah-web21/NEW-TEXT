{% doc %}
  @prompt
    create a new hero banner that also has background image that has overlay, 2 heading text where i change the text color of 2 headings 1 subtitle, 2 buttons for download my resume and view my resume each button should have a link . where the download my resume button has and external link where they can see my resume and the view services is they will redirected to services section 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: {{ block.settings.text_alignment }};
    padding: 40px 20px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-hero-banner__heading-1-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_1_size }}px;
    color: {{ block.settings.heading_1_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-hero-banner__heading-2-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_2_size }}px;
    color: {{ block.settings.heading_2_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-hero-banner__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 32px;
    line-height: 1.5;
  }

  .ai-hero-banner__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    justify-content: {{ block.settings.text_alignment }};
    flex-wrap: wrap;
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-hero-banner__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_1_bg_color }};
    color: {{ block.settings.button_1_text_color }};
  }

  .ai-hero-banner__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_1_hover_bg_color }};
    color: {{ block.settings.button_1_hover_text_color }};
  }

  .ai-hero-banner__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_2_bg_color }};
    color: {{ block.settings.button_2_text_color }};
  }

  .ai-hero-banner__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_2_hover_bg_color }};
    color: {{ block.settings.button_2_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height | times: 0.7 }}px;
    }

    .ai-hero-banner__heading-1-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_1_size | times: 0.7 }}px;
    }

    .ai-hero-banner__heading-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_2_size | times: 0.7 }}px;
    }

    .ai-hero-banner__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-hero-banner__buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-banner__background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-banner__content-{{ ai_gen_id }}">
    {% if block.settings.heading_1 != blank %}
      <h1 class="ai-hero-banner__heading-1-{{ ai_gen_id }}">{{ block.settings.heading_1 }}</h1>
    {% endif %}

    {% if block.settings.heading_2 != blank %}
      <h2 class="ai-hero-banner__heading-2-{{ ai_gen_id }}">{{ block.settings.heading_2 }}</h2>
    {% endif %}

    {% if block.settings.subtitle != blank %}
      <p class="ai-hero-banner__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}

    <div class="ai-hero-banner__buttons-{{ ai_gen_id }}">
      {% if block.settings.button_1_text != blank and block.settings.button_1_link != blank %}
        <a
          href="{{ block.settings.button_1_link }}"
          class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button--primary-{{ ai_gen_id }}"
          {% if block.settings.button_1_open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {{ block.settings.button_1_text }}
        </a>
      {% endif %}

      {% if block.settings.button_2_text != blank and block.settings.button_2_link != blank %}
        <a
          href="{{ block.settings.button_2_link }}"
          class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button--secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.button_2_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0.5
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Minimum height",
      "default": 500
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading 1",
      "default": "Welcome to My Portfolio"
    },
    {
      "type": "color",
      "id": "heading_1_color",
      "label": "Heading 1 color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_1_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading 1 size",
      "default": 48
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading 2",
      "default": "Professional Services"
    },
    {
      "type": "color",
      "id": "heading_2_color",
      "label": "Heading 2 color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_2_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading 2 size",
      "default": 32
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover my work and expertise"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Subtitle size",
      "default": 18
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content max width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Button 1 - Download resume"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button text",
      "default": "Download My Resume"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_1_open_new_tab",
      "label": "Open in new tab",
      "default": true
    },
    {
      "type": "color",
      "id": "button_1_bg_color",
      "label": "Background color",
      "default": "#4770db"
    },
    {
      "type": "color",
      "id": "button_1_text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_1_hover_bg_color",
      "label": "Hover background color",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "button_1_hover_text_color",
      "label": "Hover text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Button 2 - View services"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button text",
      "default": "View Services"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_2_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_2_text_color",
      "label": "Text color",
      "default": "#0e1b4d"
    },
    {
      "type": "color",
      "id": "button_2_hover_bg_color",
      "label": "Hover background color",
      "default": "#eff0f5"
    },
    {
      "type": "color",
      "id": "button_2_hover_text_color",
      "label": "Hover text color",
      "default": "#0e1b4d"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
