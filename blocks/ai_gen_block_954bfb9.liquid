{% doc %}
  @prompt
    create a new hero banner that also has background image that has overlay, 2 buttons for download my resume and view my resume each button should have a link . where the download my resume button has and external link where they can see my resume and the view services is they will redirected to services section. the 2 buttons should be easily repositioned , make the text and the buttons on the left center of the image. and make the backgrond image full width also put additional settings where i can change padding, height, of the heading, subheading, all the hero section and the image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.section_height }}px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_horizontal }}px;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-banner__background-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 400px;
  }

  .ai-hero-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_max_width }}px;
    text-align: left;
    width: 100%;
  }

  .ai-hero-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    padding: {{ block.settings.heading_padding_top }}px {{ block.settings.heading_padding_horizontal }}px {{ block.settings.heading_padding_bottom }}px {{ block.settings.heading_padding_horizontal }}px;
    line-height: {{ block.settings.heading_line_height }};
  }

  .ai-hero-banner__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.subheading_margin_bottom }}px;
    padding: {{ block.settings.subheading_padding_top }}px {{ block.settings.subheading_padding_horizontal }}px {{ block.settings.subheading_padding_bottom }}px {{ block.settings.subheading_padding_horizontal }}px;
    line-height: {{ block.settings.subheading_line_height }};
  }

  .ai-hero-banner__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid transparent;
  }

  .ai-hero-banner__button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_text_color }};
    border-color: {{ block.settings.button_primary_bg }};
  }

  .ai-hero-banner__button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    border-color: {{ block.settings.button_primary_hover_bg }};
  }

  .ai-hero-banner__button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text_color }};
    border-color: {{ block.settings.button_secondary_border }};
  }

  .ai-hero-banner__button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    border-color: {{ block.settings.button_secondary_hover_border }};
  }

  .ai-hero-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 4;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      height: {{ block.settings.section_height_mobile }}px;
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px;
    }

    .ai-hero-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      padding: {{ block.settings.heading_padding_top_mobile }}px {{ block.settings.heading_padding_horizontal_mobile }}px {{ block.settings.heading_padding_bottom_mobile }}px {{ block.settings.heading_padding_horizontal_mobile }}px;
    }

    .ai-hero-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
      padding: {{ block.settings.subheading_padding_top_mobile }}px {{ block.settings.subheading_padding_horizontal_mobile }}px {{ block.settings.subheading_padding_bottom_mobile }}px {{ block.settings.subheading_padding_horizontal_mobile }}px;
    }

    .ai-hero-banner__buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<hero-banner-{{ ai_gen_id }}
  class="ai-hero-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-banner__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-hero-banner__background-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-hero-banner__background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-banner__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-hero-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-hero-banner__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    <div class="ai-hero-banner__buttons-{{ ai_gen_id }}">
      {% if block.settings.button_primary_label != blank %}
        <a
          href="{{ block.settings.button_primary_link }}"
          class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button-primary-{{ ai_gen_id }}"
          {% if block.settings.button_primary_link == blank %}
            role="button"
            aria-disabled="true"
          {% endif %}
        >
          {{ block.settings.button_primary_label }}
        </a>
      {% endif %}

      {% if block.settings.button_secondary_label != blank %}
        <a
          href="{{ block.settings.button_secondary_link }}"
          class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button-secondary-{{ ai_gen_id }}"
          {% if block.settings.button_secondary_link == blank %}
            role="button"
            aria-disabled="true"
          {% endif %}
        >
          {{ block.settings.button_secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>

  {% unless block.settings.background_image %}
    <div class="ai-hero-banner__empty-state-{{ ai_gen_id }}">
      Next, add a background image
    </div>
  {% endunless %}
</hero-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('hero-banner-{{ ai_gen_id }}', HeroBanner{{ ai_gen_id }});
  })();
</script>

