{% doc %}
  @prompt
    create a new nav bar containing the logo on the left and Home
    About
    Services
    Work Samples
    What I Bring
    Contact on the right note that it doens't need an add to cart or button this is a prortfolio website
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-portfolio-nav-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    position: {{ block.settings.position }};
    top: 0;
    left: 0;
    z-index: 1000;
    box-shadow: {{ block.settings.shadow_opacity | divided_by: 100.0 | times: 0.1 }} {{ block.settings.shadow_offset }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-portfolio-nav__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.padding_horizontal }}px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ai-portfolio-nav__logo-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
  }

  .ai-portfolio-nav__logo-image-{{ ai_gen_id }} {
    max-height: {{ block.settings.logo_height }}px;
    width: auto;
  }

  .ai-portfolio-nav__logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_height | times: 1.5 }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-portfolio-nav__logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .ai-portfolio-nav__logo-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_text_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    text-decoration: none;
  }

  .ai-portfolio-nav__menu-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.menu_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-portfolio-nav__menu-item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-portfolio-nav__link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_size }}px;
    font-weight: {{ block.settings.link_weight }};
    transition: color 0.3s ease;
  }

  .ai-portfolio-nav__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.hover_color }};
  }

  .ai-portfolio-nav__mobile-toggle-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-portfolio-nav__mobile-toggle-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-portfolio-nav__mobile-toggle-{{ ai_gen_id }} {
      display: block;
    }

    .ai-portfolio-nav__menu-{{ ai_gen_id }} {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: {{ block.settings.background_color }};
      flex-direction: column;
      gap: 0;
      padding: 20px {{ block.settings.padding_horizontal }}px;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 0.3s ease, opacity 0.3s ease;
    }

    .ai-portfolio-nav__menu-{{ ai_gen_id }}.active {
      max-height: 500px;
      opacity: 1;
    }

    .ai-portfolio-nav__menu-item-{{ ai_gen_id }} {
      padding: 12px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .ai-portfolio-nav__menu-item-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }
  }
{% endstyle %}

<portfolio-nav-{{ ai_gen_id }}
  class="ai-portfolio-nav-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-portfolio-nav__container-{{ ai_gen_id }}">
    <div class="ai-portfolio-nav__logo-{{ ai_gen_id }}">
      {% if block.settings.logo != blank %}
        <img
          src="{{ block.settings.logo | image_url: height: block.settings.logo_height | times: 2 }}"
          alt="{{ shop.name }}"
          class="ai-portfolio-nav__logo-image-{{ ai_gen_id }}"
          height="{{ block.settings.logo_height }}"
          loading="lazy"
        >
      {% elsif block.settings.logo_text != blank %}
        <a href="/" class="ai-portfolio-nav__logo-text-{{ ai_gen_id }}">
          {{ block.settings.logo_text }}
        </a>
      {% else %}
        <div class="ai-portfolio-nav__logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <button
      class="ai-portfolio-nav__mobile-toggle-{{ ai_gen_id }}"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <nav>
      <ul class="ai-portfolio-nav__menu-{{ ai_gen_id }}">
        {% if block.settings.link_1_text != blank %}
          <li class="ai-portfolio-nav__menu-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.link_1_url }}"
              class="ai-portfolio-nav__link-{{ ai_gen_id }}"
            >
              {{ block.settings.link_1_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.link_2_text != blank %}
          <li class="ai-portfolio-nav__menu-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.link_2_url }}"
              class="ai-portfolio-nav__link-{{ ai_gen_id }}"
            >
              {{ block.settings.link_2_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.link_3_text != blank %}
          <li class="ai-portfolio-nav__menu-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.link_3_url }}"
              class="ai-portfolio-nav__link-{{ ai_gen_id }}"
            >
              {{ block.settings.link_3_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.link_4_text != blank %}
          <li class="ai-portfolio-nav__menu-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.link_4_url }}"
              class="ai-portfolio-nav__link-{{ ai_gen_id }}"
            >
              {{ block.settings.link_4_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.link_5_text != blank %}
          <li class="ai-portfolio-nav__menu-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.link_5_url }}"
              class="ai-portfolio-nav__link-{{ ai_gen_id }}"
            >
              {{ block.settings.link_5_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.link_6_text != blank %}
          <li class="ai-portfolio-nav__menu-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.link_6_url }}"
              class="ai-portfolio-nav__link-{{ ai_gen_id }}"
            >
              {{ block.settings.link_6_text }}
            </a>
          </li>
        {% endif %}
      </ul>
    </nav>
  </div>
</portfolio-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class PortfolioNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.toggle = this.querySelector('.ai-portfolio-nav__mobile-toggle-{{ ai_gen_id }}');
        this.menu = this.querySelector('.ai-portfolio-nav__menu-{{ ai_gen_id }}');
        
        if (this.toggle && this.menu) {
          this.toggle.addEventListener('click', this.toggleMenu.bind(this));
        }
      }

      toggleMenu() {
        const isActive = this.menu.classList.contains('active');
        this.menu.classList.toggle('active');
        this.toggle.setAttribute('aria-expanded', !isActive);
      }
    }

    customElements.define('portfolio-nav-{{ ai_gen_id }}', PortfolioNav{{ ai_gen_id }});
  })();
</script>

